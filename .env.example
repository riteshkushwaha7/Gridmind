# ============================================
# GRIDMIND — Environment Configuration
# Copy to .env and fill in values
# ============================================

# --- INFRASTRUCTURE ---
# REQUIRED
REDIS_URL=redis://redis:6379/0
POSTGRES_URL=postgresql://gridmind:gridmind@postgresql:5432/gridmind
POSTGRES_USER=gridmind
POSTGRES_PASSWORD=gridmind
POSTGRES_DB=gridmind
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=replace-with-long-random-token
INFLUXDB_USER=gridmind
INFLUXDB_PASSWORD=gridmind-admin
INFLUXDB_ORG=gridmind
INFLUXDB_BUCKET=gridmind

# --- ML TRACKING ---
# REQUIRED
MLFLOW_TRACKING_URI=http://mlflow:5000
# OPTIONAL: defaults set per-service inside config.py
MLFLOW_EXPERIMENT_NAME=gridmind

# --- EXTERNAL APIS ---
# REQUIRED for the weather node
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1
# OPTIONAL: defaults to Bengaluru (12.9716, 77.5946)
OPENMETEO_LAT=12.9716
OPENMETEO_LON=77.5946

# --- INTER-SERVICE URLS (Docker DNS names) ---
# OPTIONAL: backend services discover each other via these. Override only when running outside compose.
DATA_NODES_URL=http://data-nodes:8001
LSTM_URL=http://backend-lstm:8010
PPO_URL=http://backend-ppo:8011
CLUSTERING_URL=http://backend-clustering:8012
GATEWAY_URL=http://backend-gateway:8000

# --- SERVICE PORTS (host bindings) ---
# OPTIONAL: edit only if a port collides on the host
GATEWAY_PORT=8000
NODE_PORT=8001
LSTM_PORT=8010
PPO_PORT=8011
CLUSTERING_PORT=8012

# --- FRONTEND ---
# REQUIRED — gateway URL the browser hits
NEXT_PUBLIC_API_URL=http://localhost:8000
# OPTIONAL — only set if you wire the optional WS feed in the frontend
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# OPTIONAL — only the planner map needs Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
# OPTIONAL — comma-separated list of allowed CORS origins on the backend gateway
FRONTEND_ORIGIN=http://localhost:3000

# OPTIONAL — frontend display flags (see frontend/.env.example for full list)
NEXT_PUBLIC_APP_NAME=GRIDMIND
NEXT_PUBLIC_VERSION=0.1.0-prototype
NEXT_PUBLIC_TARIFF_MODE=ToU
NEXT_PUBLIC_BESCOM_CONTEXT=true
NEXT_PUBLIC_DATA_MODE=synthetic

# --- ML HYPERPARAMETERS (tunable without code change) ---
# OPTIONAL: defaults from backend/config.py
LSTM_HIDDEN_SIZE=128
LSTM_SEQ_LEN=192
LSTM_HORIZON=16
LSTM_RETRAIN_INTERVAL_HOURS=24
PPO_TOTAL_TIMESTEPS=500000
PPO_UPDATE_INTERVAL_HOURS=6
PPO_REWARD_ALPHA=0.5    # cost weight
PPO_REWARD_BETA=0.3     # peak-load penalty weight
PPO_REWARD_GAMMA=0.2    # energy-delivered weight
CLUSTERING_REPLAN_INTERVAL_DAYS=7
SAFETY_HEADROOM_THRESHOLD_PCT=10   # below this → fairness fallback engages

# --- SIMULATION (data-nodes) ---
# OPTIONAL: defaults baked into data-nodes/config.py
NUM_ZONES=10
BACKFILL_DAYS=7
FAULT_RATE_PCT=3
SESSION_SEED=42

# --- ENVIRONMENT ---
NODE_ENV=development
LOG_LEVEL=INFO
DEBUG=false
